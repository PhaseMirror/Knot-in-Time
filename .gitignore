# ==========================================
# HELIX-TTD PERIMETER INGRESS FILTER (.gitignore)
# ==========================================

# 1. PII, SECRETS, & SOVEREIGNTY LEAKAGE PREVENTION
# ------------------------------------------
# Strictly blocks credentials, local audit envelopes, and PII dumps
.env
.env.*
*.pem
*.key
*.cert
secrets.json
credentials.json
# Block local Helix/DBC artifacts (prevent orphaned identities)
dbc_store/
hsm_local_state/
audit_receipts_local/
*.log
# Block raw dataset extracts that might contain PII user prompts
*.csv
*.tsv
*.jsonl
*.parquet

# 2. PYTHON SUBSTRATE (Execution Artifacts)
# ------------------------------------------
# Prevents local physics engine state from corrupting the repo
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# 3. VIRTUAL ENVIRONMENTS (Local Containment)
# ------------------------------------------
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# 4. TESTING & LINTING CACHE (Ruff, Black, Pytest)
# ------------------------------------------
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.swn
*.swo
*.swp

# 5. IDE & OS METADATA
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.code-workspace
