{
  "gicd_scan": {
    "type": "object",
    "properties": {
      "checks": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "status": {"enum": ["PASS", "FAIL"]},
            "details": {
              "oneOf": [
                {"type": "string"},
                {
                  "type": "object",
                  "properties": {
                    "jurisdiction": {
                      "enum": ["CA-FED", "CA-QC", "CA-ON", "CA-INDIGENOUS"]
                    },
                    "cloud_region": {"type": "string"}
                  },
                  "additionalProperties": true
                }
              ]
            }
          },
          "required": ["status"]
        }
      }
    }
  }
}
